# --- windows-host-mcp configuration ---
# Copy to your MCP client config as `env`, or source this file for local testing.

# === Option A: multiple hosts (CUDA box, ROCm box, ...) ===
# Point this at a JSON file (see hosts.example.json). If set, the single-host
# WINDOWS_SSH_* vars below are ignored.
# WINDOWS_HOSTS_CONFIG=/home/you/windows-host-mcp/hosts.json

# === Option B: a single host via env vars ===
# Windows machine reachable over SSH (OpenSSH Server running there)
WINDOWS_SSH_HOST=192.168.1.50
WINDOWS_SSH_PORT=22
WINDOWS_SSH_USER=builder

# Path (on THIS Linux machine) to the private key whose public half is
# installed in the Windows authorized_keys. See README for setup.
WINDOWS_SSH_KEY_PATH=/home/you/.ssh/windows_host_ed25519
# Optional passphrase for the private key above.
# WINDOWS_SSH_KEY_PASSPHRASE=

# Default shell for run_command / start_job when the caller doesn't specify one.
# One of: powershell | cmd | bash
WINDOWS_SSH_DEFAULT_SHELL=powershell

# Optional default working directory on the Windows side.
# WINDOWS_SSH_DEFAULT_CWD=C:\build

# Optional: SSH handshake timeout in ms (default 20000).
# WINDOWS_SSH_READY_TIMEOUT_MS=20000

# Optional: display name and capability labels for this single host.
# WINDOWS_SSH_HOST_NAME=default
# WINDOWS_SSH_LABELS=cuda,gpu
